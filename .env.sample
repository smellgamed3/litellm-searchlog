# =============================================================
# LiteLLM SearchLog — 环境变量示例
# 使用方法：复制本文件为 .env 并按需修改
#   cp .env.sample .env
# =============================================================

# 应用监听端口（默认 3000）
PORT=3000

# 应用监听地址（Docker 部署时保持 0.0.0.0）
HOSTNAME=0.0.0.0

# Node.js 运行环境（production / development）
NODE_ENV=production

# 实例配置（instances.json）的存储目录
# Docker 部署时建议设为 /app/data（已在 docker-compose.yaml 中配置）
# 本地开发时留空，默认使用项目根目录
DATA_DIR=
