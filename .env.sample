# =============================================================
# LiteLLM SearchLog — 环境变量示例
# 使用方法：复制本文件为 .env 并按需修改
#   cp .env.sample .env
# =============================================================

# 应用监听端口（默认 3000）
PORT=3000

# 应用监听地址（Docker 部署时保持 0.0.0.0）
HOSTNAME=0.0.0.0

# Node.js 运行环境（production / development）
NODE_ENV=production

# 实例配置（instances.json）的存储目录
# Docker 部署时建议设为 /app/data（已在 docker-compose.yaml 中配置）
# 本地开发时留空，默认使用项目根目录
DATA_DIR=

# =============================================================
# 子路径 & 域名配置（用于反向代理 / HTTPS 子路径部署）
# =============================================================

# 应用部署的子路径前缀（仅在构建时生效，运行时修改无效）
# 留空表示部署在根路径 /
# 示例：BASE_PATH=/logs
# 使用方式：
#   docker build --build-arg BASE_PATH=/logs -t my-searchlog .
#   然后在 docker-compose 中同步设置 BASE_PATH=/logs（供健康检查使用）
BASE_PATH=

# 应用的公开访问 URL（可选），格式为完整 URL（含协议、域名、子路径）
# 用于应用元数据和页面标题显示，帮助管理员快速识别访问入口
# 留空则不显示
# 示例：APP_URL=https://example.com/logs
APP_URL=
